# Example terraform.tfvars for the App Gateway transit demonstrator.
# Copy this file to terraform.tfvars and fill in real values.

# Databricks account configuration.
databricks_account_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

databricks_workspace_ids = [
  "1234567890123456",
]

# Confluent Cloud Private Link configuration.
# Use the service alias for the Kafka cluster zone used by this core demo.
confluent_private_link_service_alias = "s-xxxxx.privatelink.confluent.cloud"

# Bootstrap server exactly as Databricks Spark should use it.
confluent_bootstrap_servers = "lkc-123abc-4kgzg.eastus.azure.confluent.cloud:9092"

# Domains Databricks NCC must intercept for bootstrap and broker metadata
# re-resolution. Use the DNS domain/subdomain values from Confluent Cloud.
confluent_ncc_domain_names = [
  "lkc-123abc-4kgzg.eastus.azure.confluent.cloud",
  "*.4kgzg.eastus.azure.confluent.cloud",
]

# Azure configuration.
resource_group_name = "rg-confluent-transit"
location            = "eastus"

# Defaults shown for clarity.
# vnet_address_space                      = ["10.200.0.0/16"]
# appgw_subnet_address_prefix             = "10.200.1.0/24"
# pe_subnet_address_prefix                = "10.200.2.0/24"
# appgw_privatelink_subnet_address_prefix = "10.200.3.0/24"
# appgw_frontend_ip                       = "10.200.1.10"
# appgw_sku_capacity                      = 2
# kafka_port                              = 9092
# auto_approve_databricks_pe              = true

tags = {
  Environment = "production"
  Team        = "data-engineering"
  Project     = "kafka-streaming"
}
