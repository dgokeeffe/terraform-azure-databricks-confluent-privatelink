# Copy to terraform.tfvars and fill in placeholders.

azure_subscription_id   = "00000000-0000-0000-0000-000000000000"
azure_tenant_id         = "00000000-0000-0000-0000-000000000000"
resource_group_name     = "rg-confluent-smoke-test"

databricks_account_id   = "00000000-0000-0000-0000-000000000000"
databricks_workspace_id = "1234567890123456"  # numeric workspace ID, not the resource ID

# Anything except a reserved TLD (.internal, .local, .test).
# The cert SAN regenerates to match — change it freely.
test_fqdn               = "smoke-broker.appgw-test.example.com"
